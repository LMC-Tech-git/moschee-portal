# =============================================================================
# Moschee-Portal — Umgebungsvariablen
# =============================================================================
# Kopiere diese Datei und passe die Werte an:
#   cp .env.local.example .env.local
#
# Für Produktion (Vercel):
#   Settings → Environment Variables → alle Variablen eintragen
#
# ⚠️  .env.local NIEMALS in Git committen!
#     (ist bereits in .gitignore)
# =============================================================================


# -----------------------------------------------------------------------------
# POCKETBASE — Backend (Hetzner VPS)
# -----------------------------------------------------------------------------
# Lokal:       http://91.98.142.128:8090
# Produktion:  https://api.moschee.app
NEXT_PUBLIC_POCKETBASE_URL=http://91.98.142.128:8090

# Server-seitige PB-URL (optional, Fallback: NEXT_PUBLIC_POCKETBASE_URL)
# In Produktion denselben Wert wie oben setzen
POCKETBASE_URL=http://91.98.142.128:8090

# PocketBase Admin-Zugangsdaten (nur Server-seitig, nie ans Frontend!)
PB_ADMIN_EMAIL=admin@example.com
PB_ADMIN_PASSWORD=your-secure-admin-password


# -----------------------------------------------------------------------------
# APP-URL
# -----------------------------------------------------------------------------
# Lokal:       http://localhost:3000
# Produktion:  https://moschee.app
NEXT_PUBLIC_APP_URL=http://localhost:3000


# -----------------------------------------------------------------------------
# STRIPE — Zahlungen
# -----------------------------------------------------------------------------
# Schlüssel unter: https://dashboard.stripe.com/test/apikeys
# Test-Schlüssel beginnen mit sk_test_ / pk_test_
# Live-Schlüssel beginnen mit sk_live_ / pk_live_
STRIPE_SECRET_KEY=sk_test_your-secret-key-here
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-publishable-key-here

# Webhook-Secret: https://dashboard.stripe.com/test/webhooks
# Lokal mit Stripe CLI testen: stripe listen --forward-to localhost:3000/api/stripe/webhook
# Produktion: Endpoint https://moschee.app/api/stripe/webhook eintragen
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret-here


# -----------------------------------------------------------------------------
# CLOUDFLARE TURNSTILE — CAPTCHA
# -----------------------------------------------------------------------------
# Kostenfrei, DSGVO-konform, kein Cookie-Banner nötig
# Dashboard: https://dash.cloudflare.com → Turnstile
# Ohne diese Keys: CAPTCHA wird graceful deaktiviert (kein Fehler)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x4AAAAAAA...
TURNSTILE_SECRET_KEY=0x4AAAAAAA...


# -----------------------------------------------------------------------------
# RESEND — E-Mail-Versand
# -----------------------------------------------------------------------------
# Kostenfrei bis 3.000 E-Mails/Monat
# Dashboard: https://resend.com
# Ohne diese Keys: E-Mails werden nur in der Server-Console geloggt
RESEND_API_KEY=re_your-api-key-here
# Absender-Adresse (Domain muss in Resend verifiziert sein)
# Produktion: noreply@moschee.app
RESEND_FROM_EMAIL=Moschee Portal <noreply@moschee.app>
